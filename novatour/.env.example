# ===========================
# AWS Core
# ===========================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ===========================
# Amazon Nova Services
# ===========================
NOVA_SONIC_MODEL_ID=amazon.nova-2-sonic-v1:0
NOVA_LITE_MODEL_ID=us.amazon.nova-2-lite-v1:0
NOVA_EMBEDDINGS_MODEL_ID=amazon.nova-2-multimodal-embeddings-v1:0
NOVA_ACT_API_KEY=

# ===========================
# Google APIs
# ===========================
# Gemini API key (for flight search via Search grounding) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Google Maps Platform key (Places, Routes) — https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# ===========================
# Weather
# ===========================
OPENWEATHER_API_KEY=

# ===========================
# AWS Infrastructure
# ===========================
DYNAMODB_SESSIONS_TABLE=novatour-sessions
DYNAMODB_ITINERARIES_TABLE=novatour-itineraries
DYNAMODB_PREFERENCES_TABLE=novatour-preferences
S3_ASSETS_BUCKET=

# ===========================
# App Config
# ===========================
APP_NAME=NovaTour
APP_PORT=8000
FRONTEND_PORT=3000
LOG_LEVEL=INFO
